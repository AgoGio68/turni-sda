rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // EXCEPTION FIRST: Allow public access to the messaging system so console tests can pass without Firebase Auth
    match /comunicazioni_turni/{document=**} {
      allow read, write: if true;
    }
    
    // GLOBAL CATCH-ALL SECOND: Restrict everything else to authenticated users
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
